#!/usr/bin/env python3

import json
import os
import struct
import threading
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import urlparse


BASE_DIR = Path(__file__).resolve().parent
PASSWORD_FILE = BASE_DIR / "rolepass.bin"
ADMIN_KEY = "admin@123"
XOR_KEY = "libraryxorkey"
FILE_MAP = {
    "admin": BASE_DIR / "admin.csv",
    "user": BASE_DIR / "user.csv",
    "lib": BASE_DIR / "lib.csv",
}
CODE_PREFIX = {
    "admin": "a",
    "user": "u",
    "lib": "l",
}
LOCK = threading.Lock()


def xor_crypt(data: str) -> bytes:
    key_bytes = XOR_KEY.encode("utf-8")
    data_bytes = data.encode("utf-8")
    return bytes(data_bytes[i] ^ key_bytes[i % len(key_bytes)] for i in range(len(data_bytes)))


def load_people(role: str):
    path = FILE_MAP[role]
    if not path.exists():
        return []

    people = []
    with path.open("r", encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            parts = line.split(",")
            if len(parts) != 4:
                continue
            fname, lname, email, code = parts
            people.append({
                "fname": fname,
                "lname": lname,
                "email": email,
                "code": code,
            })
    return people


def save_people(role: str, people):
    path = FILE_MAP[role]
    with path.open("w", encoding="utf-8") as handle:
        for person in people:
            handle.write(
                f"{person['fname']},{person['lname']},{person['email']},{person['code']}\n"
            )


def store_password(role: str, email: str, password: str):
    encrypted = xor_crypt(password)
    role_email_key = f"{role}|{email}".encode("utf-8")

    with PASSWORD_FILE.open("ab") as handle:
        handle.write(struct.pack("<I", len(role_email_key)))
        handle.write(role_email_key)
        handle.write(struct.pack("<I", len(encrypted)))
        handle.write(encrypted)


def check_password(role: str, email: str, password: str) -> bool:
    if not PASSWORD_FILE.exists():
        return False

    encrypted_input = xor_crypt(password)
    expected_key = f"{role}|{email}".encode("utf-8")

    with PASSWORD_FILE.open("rb") as handle:
        while True:
            raw_key_length = handle.read(4)
            if not raw_key_length:
                return False

            key_length = struct.unpack("<I", raw_key_length)[0]
            stored_key = handle.read(key_length)

            raw_password_length = handle.read(4)
            if len(raw_password_length) != 4:
                return False
            password_length = struct.unpack("<I", raw_password_length)[0]
            stored_password = handle.read(password_length)

            if stored_key == expected_key and stored_password == encrypted_input:
                return True


def require_admin_key(role: str, payload: dict):
    if role != "admin":
        return None
    if payload.get("admin_key") != ADMIN_KEY:
        return "invalid admin key"
    return None


def validate_role(role: str):
    if role not in FILE_MAP:
        return "role must be one of admin, user, or lib"
    return None


class ApiHandler(BaseHTTPRequestHandler):
    server_version = "FindMyBookApi/1.0"

    def end_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        super().end_headers()

    def do_OPTIONS(self):
        self.send_response(204)
        self.end_headers()

    def do_GET(self):
        parsed = urlparse(self.path)

        if parsed.path == "/api/health":
            self.json_response(200, {"status": "ok"})
            return

        if parsed.path == "/api/admins":
            self.json_response(200, {"items": load_people("admin")})
            return

        if parsed.path == "/api/users":
            self.json_response(200, {"items": load_people("user")})
            return

        if parsed.path == "/api/libraries":
            self.json_response(200, {"items": load_people("lib")})
            return

        self.json_response(404, {"error": "route not found"})

    def do_POST(self):
        parsed = urlparse(self.path)
        payload = self.read_json_body()
        if payload is None:
            return

        if parsed.path == "/api/signup":
            self.handle_signup(payload)
            return

        if parsed.path == "/api/login":
            self.handle_login(payload)
            return

        self.json_response(404, {"error": "route not found"})

    def handle_signup(self, payload):
        role = payload.get("role", "").strip()
        role_error = validate_role(role)
        if role_error:
            self.json_response(400, {"error": role_error})
            return

        admin_key_error = require_admin_key(role, payload)
        if admin_key_error:
            self.json_response(403, {"error": admin_key_error})
            return

        fname = payload.get("fname", "").strip()
        lname = payload.get("lname", "").strip()
        email = payload.get("email", "").strip()
        password = payload.get("password", "")

        if not fname or not lname or not email or not password:
            self.json_response(400, {"error": "fname, lname, email, and password are required"})
            return

        if "@" not in email or "." not in email.split("@", 1)[-1]:
            self.json_response(400, {"error": "invalid email format"})
            return

        if len(password) < 8:
            self.json_response(400, {"error": "password must be at least 8 characters"})
            return

        with LOCK:
            people = load_people(role)
            for person in people:
                if person["email"] == email:
                    self.json_response(409, {"error": "email already registered"})
                    return

            code = f"{CODE_PREFIX[role]}{len(people) + 1}"
            new_person = {
                "fname": fname,
                "lname": lname,
                "email": email,
                "code": code,
            }
            people.append(new_person)
            save_people(role, people)
            store_password(role, email, password)

        self.json_response(201, {
            "message": f"{role} created successfully",
            "person": new_person,
        })

    def handle_login(self, payload):
        role = payload.get("role", "").strip()
        role_error = validate_role(role)
        if role_error:
            self.json_response(400, {"error": role_error})
            return

        admin_key_error = require_admin_key(role, payload)
        if admin_key_error:
            self.json_response(403, {"error": admin_key_error})
            return

        email = payload.get("email", "").strip()
        password = payload.get("password", "")
        if not email or not password:
            self.json_response(400, {"error": "email and password are required"})
            return

        people = load_people(role)
        matched_person = next((person for person in people if person["email"] == email), None)
        if matched_person is None:
            self.json_response(404, {"error": f"{role} account not found"})
            return

        if not check_password(role, email, password):
            self.json_response(401, {"error": "invalid credentials"})
            return

        self.json_response(200, {
            "message": "login success",
            "person": matched_person,
        })

    def read_json_body(self):
        content_length = int(self.headers.get("Content-Length", "0"))
        raw_body = self.rfile.read(content_length) if content_length > 0 else b"{}"
        try:
            return json.loads(raw_body.decode("utf-8"))
        except json.JSONDecodeError:
            self.json_response(400, {"error": "invalid JSON body"})
            return None

    def json_response(self, status_code: int, payload: dict):
        body = json.dumps(payload).encode("utf-8")
        self.send_response(status_code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def main():
    port = int(os.environ.get("PORT", "8000"))
    server = ThreadingHTTPServer(("0.0.0.0", port), ApiHandler)
    print(f"API server running on http://127.0.0.1:{port}")
    server.serve_forever()


if __name__ == "__main__":
    main()
